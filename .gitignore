__pycache__/
*.pyc
*.pyo
.DS_Store
.venv/
venv/
.idea/
.vscode/
/tmp/
*.swp

# 渲染验证产物
/out/
*.pdf
slide-*.jpg
slide-*.png
preview*.png
thumbnails-*.jpg

# 但保留示例产物
!.claude/skills/pptx-deck/examples/sample_output.pptx

# evals 临时产物
evals/_run/
evals/plans/*.pptx
evals/plans/*_render/
.claude/skills/pptx-deck/examples/*_render/

# Claude Code runtime telemetry (Stop hook 写,见 .claude/settings.json)
.claude/runtime.log

# 模板提取 / deck 工作素材(版权 + 体积)
_assets/

# deck 工作目录 — 全交给 decks/.gitignore 管(默认整目录不入 git)
# 详见 decks/.gitignore

# === library/ · 知识库 ===
# 共享 RAG 基础设施(venv / 凭据 / DB)
library/_rag/.venv/
library/_rag/.env
library/_rag/.env.*
library/_rag/db.sqlite
library/_rag/.cache/

# 各 kb 的 _source/ · 用户原始材料(机密 / 版权 / 体积)
library/*/_source/*
!library/*/_source/.gitkeep

# items/<id>/{meta.yaml,preview.png} 是产品资产 · 入 git(不 ignore)

# 通用 .env 保护
**/.env
**/.env.local
**/.env.*.local
